{
  "id": "losttales:path/survivalist/night_watch",
  "title": "Path of the Survivalist: Night Watch",
  "description": "The wilds do not sleep when the sun goes down. A survivalist learns to hear the dark and answer before it reaches the firelight.",
  "repeatable": false,
  "startMode": "item",
