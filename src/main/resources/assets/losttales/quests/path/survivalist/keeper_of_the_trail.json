{
  "id": "losttales:path/survivalist/keeper_of_the_trail",
  "title": "Path of the Survivalist: Keeper of the Trail",
  "description": "The final lesson is not about surviving one night, but being ready for many. A true survivalist carries food, light, tools, and direction.",
  "repeatable": false,
  "startMode": "item",
  "prerequisites": {
    "completed": "losttales:path/survivalist/night_watch"
  },
  "journalLog": {
    "10": "The path has taught me many small habits. Now I should prepare a pack that can carry me through a long and uncertain journey.",
    "20": "I have gathered a traveler's kit worthy of the road. Wherever I go next, I will not go unprepared.",
    "30": "I have completed the first lessons of the survivalist path. The wilds are still dangerous, but they no longer feel unknowable."
  },
  "stages": [
    {
      "id": "10",
      "objectives": [
        {
          "id": "carry_food",
          "type": "gather",
          "description": "Pack 6 pieces of lasting food.",
          "optional": false,
          "params": {
            "item": "minecraft:bread,minecraft:cooked_beef,minecraft:cooked_porkchop,minecraft:cooked_chicken,minecraft:baked_potato",
            "count": "6"
          }
        },
        {
          "id": "carry_torches",
          "type": "gather",
          "description": "Pack 16 torches.",
          "optional": false,
          "params": {
            "item": "minecraft:torch",
            "count": "16"
          }
        }
      ]
    },
    {
      "id": "20",
      "objectives": [
        {
          "id": "craft_compass",
          "type": "craft",
          "description": "Craft a compass for the road ahead.",
          "optional": false,
          "params": {
            "item": "minecraft:compass",
            "count": "1"
          }
        },
        {
          "id": "craft_fishing_rod",
          "type": "craft",
          "description": "Craft a fishing rod for lean days.",
          "optional": false,
          "params": {
            "item": "minecraft:fishing_rod",
            "count": "1"
          }
        }
      ]
    },
    {
      "id": "30",
      "objectives": [
        {
          "id": "gather_fish",
          "type": "gather",
          "description": "Catch or gather 2 fish.",
          "optional": false,
          "params": {
            "item": "minecraft:fish",
            "count": "2"
          }
        }
      ]
    }
  ],
  "rewards": {
    "experience": "75",
    "items": "minecraft:emerald*2,minecraft:golden_apple*1"
  }
}
